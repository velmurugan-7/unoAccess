# ===== Server =====
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173
EXTRA_ALLOWED_ORIGINS=

# ===== MongoDB =====
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/unoaccess

# ===== JWT =====
JWT_ACCESS_SECRET=change-me-min-32-chars
JWT_REFRESH_SECRET=change-me-min-32-chars-2
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ===== Encryption =====
ENCRYPTION_KEY=64hexcharstringchangeme0000000000000000000000000000000000000000000

# ===== Email =====
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=you@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM="UnoAccess <noreply@unoaccess.com>"

# ===== Cookies =====
COOKIE_SECRET=change-me-long-random-string

# ===== Privacy =====
IP_HASH_SALT=change-me-random

# ===== Error Tracking (optional) =====
SENTRY_DSN=

# ===== NEW in v3 =====
# No new required env vars. All new features use existing credentials.
# To disable the alert worker (runs every 60s), set:
# DISABLE_ALERT_WORKER=true
